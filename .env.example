# ─── API-FOOTBALL ─────────────────────────────────────────────────────────────
# Lascia vuoto durante lo sviluppo → il server usa dati mock automaticamente
# Quando il sito è pronto, inserisci la chiave su Railway e il mock si disattiva
API_FOOTBALL_KEY=

# Base URL API-Football (non toccare)
API_FOOTBALL_BASE=https://v3.football.api-sports.io

# ─── CACHE ────────────────────────────────────────────────────────────────────
# 360 = 6 ore (4 chiamate/giorno max)
CACHE_TTL_MINUTES=360

# ─── SUPABASE (opzionale) ─────────────────────────────────────────────────────
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# NON impostare PORT su Railway: lo gestisce Railway automaticamente.
